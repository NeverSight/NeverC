#ifndef ARCHINFO
#define ARCHINFO(arch)
#endif

///
/// X86 architectures.
///
ARCHINFO(x86_64, MachO::CPU_TYPE_X86_64, MachO::CPU_SUBTYPE_X86_64_ALL, 64)

///
/// ARM64 architectures.
///
ARCHINFO(arm64, MachO::CPU_TYPE_ARM64, MachO::CPU_SUBTYPE_ARM64_ALL, 64)
