/// printInstruction - This method is automatically generated by tablegen
/// from the instruction set description.
LLVM_NO_PROFILE_INSTRUMENT_FUNCTION
void X86IntelInstPrinter::printInstruction(const MCInst *MI, uint64_t Address, raw_ostream &O) {
  O << "\t";

  auto MnemonicInfo = getMnemonic(MI);

  O << MnemonicInfo.first;

  uint64_t Bits = MnemonicInfo.second;
  assert(Bits != 0 && "Cannot print this instruction.");

  // Fragment 0 encoded into 6 bits for 46 unique commands.
  switch ((Bits >> 14) & 63) {
  default: llvm_unreachable("Invalid command number.");
  case 0:
    // DBG_VALUE, DBG_VALUE_LIST, DBG_INSTR_REF, DBG_PHI, DBG_LABEL, BUNDLE, ...
    return;
    break;
  case 1:
    // SEH_PushFrame, SEH_PushReg, SEH_SaveReg, SEH_SaveXMM, SEH_SetFrame, SE...
    printOperand(MI, 0, O);
    break;
  case 2:
    // XOR64_FP, ADC16ri, ADC16ri8, ADC16ri8_EVEX, ADC16ri_EVEX, ADC16rm, ADC...
    printOperand(MI, 1, O);
    break;
