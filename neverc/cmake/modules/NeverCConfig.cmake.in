# This file allows users to call find_package(NeverC) and pick up our targets.

@NEVERC_CONFIG_CODE@

set(LLVM_VERSION @LLVM_VERSION_MAJOR@.@LLVM_VERSION_MINOR@.@LLVM_VERSION_PATCH@)
find_package(LLVM ${LLVM_VERSION} EXACT REQUIRED CONFIG
             HINTS "@NEVERC_CONFIG_LLVM_CMAKE_DIR@")

set(NEVERC_EXPORTED_TARGETS "@NEVERC_EXPORTS@")
set(NEVERC_CMAKE_DIR "@NEVERC_CONFIG_CMAKE_DIR@")
set(NEVERC_INCLUDE_DIRS "@NEVERC_CONFIG_INCLUDE_DIRS@")
set(NEVERC_LINK_DYLIB "@NEVERC_LINK_DYLIB@")

# Provide all our library targets to users.
@NEVERC_CONFIG_INCLUDE_EXPORTS@

if(NOT TARGET neverc-tablegen-targets)
  add_custom_target(neverc-tablegen-targets)
endif()
